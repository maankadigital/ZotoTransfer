{
  "version": 2,
  "builds": [
    {
      "src": "app-src/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "transfer web"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "transfer web/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "transfer web/$1"
    }
  ]
}
